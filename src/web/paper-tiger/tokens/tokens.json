    "sm": { "value": "25rem"   },
    "md": { "value": "36rem"   },
    "tablet": { "value": "48rem"   },
    "lg": { "value": "55.5rem" },
    "desktop": { "value": "62rem" },
    "xl": { "value": "75rem"   },
    "xxl": { "value": "90rem"  }
  },

  "z": {
    "base":     { "value": 0 },
    "header":   { "value": 100 },
    "dropdown": { "value": 200 },
    "modal":    { "value": 1000 }
  }
