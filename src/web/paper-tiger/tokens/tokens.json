      "body":    { "value": "'abril-text', Georgia, 'Times New Roman', serif", "_comment": "Long-form prose, article body" },
      "label":   { "value": "'sofia-pro', 'Helvetica Neue', Arial, sans-serif" },
      "ui":      { "value": "'sofia-pro', 'Helvetica Neue', Arial, sans-serif" },
