  },

  "color": {
    "brand": {
      "100": { "value": "#411C02", "_comment": "Darkest oak — text on warm tints" },
      "90":  { "value": "#6D2E03" },
      "80":  { "value": "#C1560E" },
      "70":  { "value": "#e77500", "_comment": "Princeton Orange — primary accent, focus, footer top border" },
      "60":  { "value": "#F7964A" },
      "20":  { "value": "#FEECDE" },
      "10":  { "value": "#FFF7F2" }
    },
    "action": {
      "100": { "value": "#411C02" },
      "90":  { "value": "#6D2E03" },
      "80":  { "value": "#C1560E" },
      "70":  { "value": "#e77500" },
      "60":  { "value": "#F7964A" },
      "20":  { "value": "#FEECDE" },
      "10":  { "value": "#FFF7F2" }
    },
    "neutral": {
      "5":   { "value": "#f7f7f7", "_comment": "Page surfaces / outline-light fills" },
      "10":  { "value": "#eeeeee" },
      "20":  { "value": "#D9D9D9" },
      "40":  { "value": "#a0a0a0" },
      "60":  { "value": "#717171" },
