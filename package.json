{
  "name": "page-stream",
  "version": "0.1.0",
  "type": "module",
  "description": "Headless web page compositor & streamer to SRT/other ingests using Puppeteer + FFmpeg.",
  "scripts": {
    "build": "tsc -p tsconfig.json && cp dist/src/index.js dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "pretest": "npm run build",
    "test": "node --test dist/tests/*.test.js",
    "control-api": "node dist/src/control-api/index.js",
    "cli": "node dist/src/cli/index.js",
    "tui": "node dist/src/tui/index.js"
  },
  "dependencies": {
    "commander": "^14.0.3",
  "playwright": "1.58.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "engines": {"node": ">=20"},
  "license": "MIT"
}
